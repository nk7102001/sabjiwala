<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>My Orders — Sabjiwala</title>
</head>
<body class="sw-page">
  <%- include('partials/navbar') %>
  <main class="sw-main max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
    <div class="flex items-center gap-3 mb-8 anim-fade-up">
      <span class="text-3xl">📦</span>
      <h1 class="sw-heading text-2xl sm:text-3xl">My Orders</h1>
    </div>

    <% if (orders.length === 0) { %>
      <div class="sw-card p-12 text-center anim-scale-in">
        <div class="text-5xl mb-4">📭</div>
        <h3 style="font-family:'Syne',sans-serif" class="text-xl font-bold text-gray-600 mb-2">No Orders Yet</h3>
        <p class="text-gray-400 mb-6">Start shopping and your orders will appear here.</p>
        <a href="/" class="sw-btn sw-btn-primary px-6 py-2.5">Shop Now →</a>
      </div>
    <% } else { %>
      <div class="space-y-6">
        <% orders.forEach((order, i) => { %>
          <div class="sw-card overflow-hidden anim-fade-up" style="animation-delay:<%=i*0.08%>s">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 px-5 py-4 bg-gradient-to-r from-green-50 to-white border-b border-green-100">
              <div>
                <span class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Order ID</span>
                <p class="font-mono text-sm font-bold text-gray-700"><%= order._id %></p>
              </div>
              <div class="flex items-center gap-3">
                <span class="sw-badge <%= order.status==='Delivered'?'sw-badge-green':order.status==='Cancelled'?'sw-badge-red':'sw-badge-yellow' %>"><%= order.status||'Pending' %></span>
                <span class="text-xs text-gray-400"><%= order.createdAt.toLocaleString() %></span>
              </div>
            </div>
            <div class="overflow-x-auto">
              <table class="sw-table min-w-[500px]">
                <thead><tr><th>Product</th><th>Vendor</th><th>Price</th><th>Qty</th><th>Subtotal</th></tr></thead>
                <tbody>
                  <% order.items.forEach(item => { %>
                    <tr>
                      <td class="font-semibold"><%= item.product?.name || 'Deleted Product' %></td>
                      <td class="text-gray-500 text-sm"><%= item.vendor?.shopName || item.vendor?.name || 'N/A' %></td>
                      <td>₹<%= item.price %></td>
                      <td><%= item.qty %></td>
                      <td class="font-bold text-green-700">₹<%= item.qty * item.price %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <div class="flex justify-end px-5 py-4 border-t border-green-50">
              <span class="font-black text-green-700 text-lg" style="font-family:'Syne',sans-serif">Total: ₹<%= order.total %></span>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
