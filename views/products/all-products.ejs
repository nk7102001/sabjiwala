<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>All Products — Sabjiwala</title>
</head>
<body class="sw-page">
  <%- include('../partials/navbar') %>
  <main class="sw-main max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="flex items-center gap-3 mb-8 anim-fade-up">
      <span class="text-3xl">🥦</span>
      <h1 class="sw-heading text-2xl sm:text-3xl">All Products</h1>
    </div>

    <% const _products = Array.isArray(products) ? products : []; %>
    <% if (_products.length === 0) { %>
      <div class="sw-card p-12 text-center anim-scale-in">
        <div class="text-5xl mb-4">😕</div>
        <h3 style="font-family:'Syne',sans-serif" class="text-xl font-bold text-gray-600">No products available</h3>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 sm:gap-6">
        <% _products.forEach((prod, i) => { %>
          <div class="sw-card overflow-hidden flex flex-col anim-fade-up" style="animation-delay:<%=i*0.06%>s">
            <div class="relative overflow-hidden bg-green-50 h-44">
              <% if (prod.imageUrl) { %>
                <img src="<%= prod.imageUrl %>" alt="<%= prod.name||'Product' %>"
                  class="h-full w-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center text-5xl">🥦</div>
              <% } %>
              <% const qty = Number(prod.availableQty||0); %>
              <% if (qty === 0) { %>
                <span class="absolute top-2 right-2 sw-badge sw-badge-red">Out of Stock</span>
              <% } else if (qty <= 5) { %>
                <span class="absolute top-2 right-2 sw-badge sw-badge-yellow">⚡ <%= qty %> left</span>
              <% } else { %>
                <span class="absolute top-2 right-2 sw-badge sw-badge-green">✅ In Stock</span>
              <% } %>
            </div>
            <div class="p-4 flex flex-col flex-1">
              <span class="text-xs text-gray-400 mb-1"><%= prod.category||'' %></span>
              <h2 class="font-bold text-gray-800 text-base line-clamp-1 mb-1" style="font-family:'Syne',sans-serif"><%= prod.name||'Product' %></h2>
              <p class="text-green-700 font-black text-lg mb-3">₹<%= Number(prod.pricePerKg||0) %><span class="text-gray-400 text-xs font-normal">/kg</span></p>
              <div class="mt-auto flex flex-col gap-2">
                <a href="/products/<%= prod.slug %>" class="sw-btn sw-btn-outline w-full py-2 text-sm">View Vendors</a>
                <form action="/cart/add/<%= prod._id %>" method="POST">
                  <button type="submit" class="sw-btn sw-btn-primary w-full py-2 text-sm">Add to Cart 🛒</button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
