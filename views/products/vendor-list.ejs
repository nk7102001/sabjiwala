<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Vendors for <%= product && product.name ? product.name : 'Product' %> — Sabjiwala</title>
</head>
<body class="sw-page">
  <%- include('../partials/navbar') %>
  <main class="sw-main max-w-4xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
    <div class="anim-fade-up mb-8">
      <p class="text-sm text-gray-400 mb-1">Vendors selling</p>
      <h2 class="sw-heading text-2xl sm:text-3xl"><%= product && product.name ? product.name : '' %></h2>
    </div>

    <% const _vendors = Array.isArray(vendors) ? vendors : []; %>
    <% if (_vendors.length === 0) { %>
      <div class="sw-card p-10 text-center anim-scale-in">
        <div class="text-5xl mb-3">😕</div>
        <p class="text-gray-500">Koi vendor abhi available nahi hai.</p>
      </div>
    <% } else { %>
      <div class="space-y-5">
        <% _vendors.forEach((vendor, i) => {
            const prod = (vendor && Array.isArray(vendor.products))
              ? vendor.products.find(p => p.product && product && p.product.toString() === product._id.toString())
              : null;
            if (!prod) return;
        %>
        <div class="sw-card p-6 anim-fade-up" style="animation-delay:<%=i*0.08%>s">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center text-2xl flex-shrink-0">🏪</div>
              <div>
                <span class="font-bold text-lg text-green-700" style="font-family:'Syne',sans-serif"><%= vendor.shopName || vendor.name || 'Vendor' %></span>
                <p class="text-sm text-gray-500">📞 <%= vendor.phone || '—' %> · 📍 <%= vendor.address || '' %> <%= vendor.city || '' %></p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="sw-badge <%= Number(prod.availableQty||0)>0 ? 'sw-badge-green' : 'sw-badge-red' %>">
                <%= Number(prod.availableQty||0)>0 ? '✅ Available' : '❌ Out of Stock' %>
              </span>
              <% if (typeof prod.rating !== 'undefined' && prod.rating !== null) { %>
                <span class="sw-badge sw-badge-yellow">⭐ <%= prod.rating %></span>
              <% } %>
            </div>
          </div>

          <div class="flex flex-wrap items-center gap-4 mb-4">
            <div class="bg-green-50 rounded-xl px-4 py-2.5">
              <p class="text-xs text-gray-400">Price</p>
              <p class="font-black text-green-700 text-lg" style="font-family:'Syne',sans-serif">₹<%= Number(prod.price||0) %><span class="text-xs font-normal text-gray-400">/kg</span></p>
            </div>
            <div class="bg-green-50 rounded-xl px-4 py-2.5">
              <p class="text-xs text-gray-400">Available</p>
              <p class="font-bold text-gray-700"><%= Number(prod.availableQty||0) %> kg</p>
            </div>
          </div>

          <% if (Number(prod.availableQty||0) > 0) { %>
            <form action="/cart/add" method="POST" class="flex items-center gap-3">
              <input type="hidden" name="vendorId" value="<%= vendor._id %>">
              <input type="hidden" name="vendorName" value="<%= vendor.shopName || vendor.name || '' %>">
              <input type="hidden" name="productId" value="<%= product && product._id ? product._id : '' %>">
              <input type="hidden" name="productName" value="<%= product && product.name ? product.name : '' %>">
              <input type="hidden" name="price" value="<%= Number(prod.price||0) %>">
              <div class="sw-stepper">
                <button type="button" class="sw-stepper-btn" onclick="const i=this.nextElementSibling;i.value=Math.max(1,+i.value-1)">−</button>
                <input type="number" name="qty" min="1" max="<%= Number(prod.availableQty||0) %>" value="1" class="sw-stepper-input w-14" />
                <button type="button" class="sw-stepper-btn" onclick="const i=this.previousElementSibling;i.value=Math.min(<%= Number(prod.availableQty||0) %>,+i.value+1)">+</button>
              </div>
              <button type="submit" class="sw-btn sw-btn-primary px-5 py-2 text-sm">Add to Cart 🛒</button>
            </form>
          <% } %>
        </div>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
