<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Contact — Sabjiwala</title>
</head>
<body class="sw-page">
  <%- include('partials/navbar') %>
  <main class="sw-main max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-16">
    <div class="text-center mb-10 anim-fade-up">
      <span class="text-5xl block mb-4">📬</span>
      <h1 class="sw-heading text-3xl sm:text-4xl mx-auto mb-2">Get In Touch</h1>
      <p class="text-gray-500 text-base max-w-md mx-auto">Have a question or feedback? We'd love to hear from you.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
      <!-- Contact Info -->
      <div class="lg:col-span-2 space-y-5 anim-fade-up delay-100">
        <% [
          ['📧','Email','support@sabjiwala.com','mailto:support@sabjiwala.com'],
          ['📞','Phone','+91 9876543210','tel:+919876543210'],
          ['📍','Address','123 Sabjiwala Street, City, India',null],
          ['🕐','Hours','Mon–Sat, 9 AM – 7 PM',null],
        ].forEach(([ico,label,val,href]) => { %>
          <div class="sw-card p-5 flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center text-xl flex-shrink-0"><%= ico %></div>
            <div>
              <p class="text-xs text-gray-400 font-semibold uppercase tracking-wide mb-0.5"><%= label %></p>
              <% if (href) { %>
                <a href="<%= href %>" class="font-semibold text-green-700 hover:text-green-600 text-sm"><%= val %></a>
              <% } else { %>
                <p class="font-semibold text-gray-700 text-sm"><%= val %></p>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-3 anim-fade-up delay-200">
        <div class="sw-card p-6 sm:p-8">
          <h2 class="font-bold text-gray-800 text-lg mb-6" style="font-family:'Syne',sans-serif">Send us a Message</h2>

          <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length) { %>
            <div class="sw-alert sw-alert-success mb-5">✅ <%= Array.isArray(success_msg) ? success_msg.join(' · ') : success_msg %></div>
          <% } %>
          <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length) { %>
            <div class="sw-alert sw-alert-error mb-5">⚠️ <%= Array.isArray(error_msg) ? error_msg.join(' · ') : error_msg %></div>
          <% } %>

          <form action="/contact" method="POST" class="space-y-5" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="sw-label">Your Name</label>
                <input type="text" name="name" placeholder="Rahul Sharma" required class="sw-input" />
              </div>
              <div>
                <label class="sw-label">Email Address</label>
                <input type="email" name="email" placeholder="rahul@example.com" required class="sw-input" />
              </div>
            </div>
            <div>
              <label class="sw-label">Subject</label>
              <input type="text" name="subject" placeholder="How can we help?" class="sw-input" />
            </div>
            <div>
              <label class="sw-label">Message</label>
              <textarea name="message" rows="5" placeholder="Write your message here..." required class="sw-input resize-none"></textarea>
            </div>
            <button type="submit" class="sw-btn sw-btn-primary w-full py-3 text-base">🚀 Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
