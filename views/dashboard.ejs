<%- include('partials/navbar') %>
<main class="sw-main max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
  <!-- Welcome Banner -->
  <div class="relative overflow-hidden rounded-2xl mb-10 anim-fade-up"
       style="background: linear-gradient(135deg,#16a34a 0%,#15803d 60%,#166534 100%)">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute -right-10 -top-10 w-64 h-64 rounded-full bg-white"></div>
    </div>
    <div class="relative p-8 sm:p-10">
      <p class="text-green-300 text-sm mb-1">Seller Panel</p>
      <h1 class="text-3xl font-black text-white mb-1" style="font-family:'Syne',sans-serif">
        Welcome, <%= (seller && seller.name) ? seller.name : 'Seller' %>! 👋
      </h1>
      <p class="text-green-200 text-sm">Manage your store, track your performance</p>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
    <% [
      ['/seller/products/add','➕','Add Product','List new products','#16a34a,#15803d'],
      ['/seller/products','📦','My Products','View & edit listings','#3b82f6,#2563eb'],
      ['/seller/analytics','📊','Analytics','Track performance','#a855f7,#9333ea'],
      ['/seller-logout','🚪','Logout','Exit your account','#ef4444,#dc2626'],
    ].forEach(([href,ico,title,desc,grad], i) => { %>
      <a href="<%= href %>" class="group relative overflow-hidden rounded-2xl p-6 text-white shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1 anim-fade-up" style="background:linear-gradient(135deg,<%=grad%>);animation-delay:<%=i*0.1%>s">
        <div class="text-4xl mb-3 group-hover:scale-110 transition-transform duration-300 block"><%= ico %></div>
        <h3 class="font-bold text-base mb-0.5" style="font-family:'Syne',sans-serif"><%= title %></h3>
        <p class="text-white/70 text-xs"><%= desc %></p>
      </a>
    <% }) %>
  </div>
</main>
<%- include('partials/footer') %>
