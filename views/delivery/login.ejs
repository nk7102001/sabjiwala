<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Delivery Login — Sabjiwala</title>
</head>
<body class="sw-page" style="background: linear-gradient(135deg,#f0fdf4 0%,#dcfce7 50%,#fef9c3 100%)">
  <%- include('../partials/navbar') %>
  <main class="flex-1 flex items-center justify-center px-4 py-16">
    <div class="sw-card w-full max-w-md p-8 sm:p-10 anim-scale-in">
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-blue-100 text-4xl mb-4 anim-bounce-in">🚴</div>
        <h2 class="sw-heading text-2xl sm:text-3xl text-center">Delivery Login</h2>
        <p class="text-gray-500 text-sm mt-1">Welcome back! Start your deliveries today.</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="sw-alert sw-alert-error mb-5">⚠️ <%= Array.isArray(error) ? error.join(' · ') : error %></div>
      <% } %>

      <form action="/delivery/login" method="POST" class="space-y-5" novalidate>
        <div>
          <label class="sw-label">Mobile Number</label>
          <input type="text" name="mobile" placeholder="10-digit phone number" required autofocus class="sw-input" />
        </div>
        <div>
          <label class="sw-label">Password</label>
          <div class="relative">
            <input type="password" id="dlpwd" name="password" placeholder="Your password" required class="sw-input pr-10" />
            <button type="button" onclick="const i=document.getElementById('dlpwd');i.type=i.type==='password'?'text':'password';this.textContent=i.type==='password'?'👁️':'🙈'" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm">👁️</button>
          </div>
        </div>
        <button type="submit" class="sw-btn sw-btn-primary w-full py-3 text-base">🚴 Login to Dashboard</button>
      </form>

      <div class="flex items-center gap-3 my-5">
        <div class="flex-1 h-px bg-gray-200"></div><span class="text-xs text-gray-400 font-semibold">OR</span><div class="flex-1 h-px bg-gray-200"></div>
      </div>

      <a href="/auth/google?role=delivery" class="sw-btn sw-btn-outline w-full py-2.5 text-sm gap-2">
        <svg class="w-5 h-5" viewBox="0 0 48 48"><g><path fill="#4285F4" d="M24 9.5c3.54 0 6.4 1.49 8.35 2.73L38.77 7.38C34.94 4.51 29.91 2.5 24 2.5c-9.02 0-16.56 5.32-20.63 13.73l8.6 6.69C14.24 16.52 19.35 9.5 24 9.5z"/><path fill="#34A853" d="M46.15 24.48c0-2.22-.18-4.35-.51-6.42H24v12.11h12.48c-.54 2.76-2.16 5.11-4.09 6.7l8.1 6.28C43.69 38.92 46.15 32.16 46.15 24.48z"/><path fill="#FBBC05" d="M12.97 28.92c-.68-2.06-1.07-4.24-1.07-6.41s.39-4.35 1.05-6.42L4.35 9.22C2.38 12.25 1.26 15.89 1.26 19.8s1.1 7.55 3.08 10.58l8.63-6.9z"/><path fill="#EA4335" d="M24 46.5c5.17 0 9.57-1.71 12.76-4.64l-8.1-6.28c-2.27 1.53-5.18 2.4-8.66 2.4-6.04 0-11.15-3.93-13.1-9.39l-8.63 6.9C6.43 40.18 14.97 46.5 24 46.5z"/></g></svg>
        Login with Google
      </a>

      <p class="text-center text-sm text-gray-500 mt-6">
        New here? <a href="/delivery/signup" class="text-green-600 font-semibold hover:underline">Become a Delivery Guy →</a>
      </p>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
