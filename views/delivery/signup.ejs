<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Become a Delivery Guy — Sabjiwala</title>
</head>
<body class="sw-page">
  <%- include('../partials/navbar') %>

  <section class="sw-hero-bg border-b border-green-100 py-12">
    <div class="max-w-xl mx-auto px-4 text-center anim-fade-up">
      <span class="text-5xl block mb-4">🚴</span>
      <h1 class="sw-heading text-3xl sm:text-4xl mx-auto mb-2">Become a Delivery Guy</h1>
      <p class="text-gray-600 text-base">Flexible timings, great earnings. Join our delivery team today!</p>
      <div class="flex justify-center flex-wrap gap-3 mt-5">
        <% [['💰','Earn Daily'],['⏰','Flexible Hours'],['🗺️','Your City'],['🚀','Fast Onboarding']].forEach(([i,t]) => { %>
          <span class="flex items-center gap-1.5 bg-white border border-green-100 text-green-700 px-3 py-1.5 rounded-full text-xs font-semibold shadow-sm"><%= i %> <%= t %></span>
        <% }) %>
      </div>
    </div>
  </section>

  <main class="sw-main max-w-md mx-auto px-4 py-10">
    <% if (typeof errors !== 'undefined' && errors && errors.length) { %>
      <div class="sw-alert sw-alert-error mb-5 anim-fade-up">
        <ul class="list-disc list-inside"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
      </div>
    <% } %>

    <div class="sw-card p-6 sm:p-8 anim-fade-up delay-100">
      <form action="/delivery/signup" method="POST" class="space-y-5" novalidate>
        <div>
          <label class="sw-label">Full Name</label>
          <input type="text" name="name" placeholder="Arjun Singh" required
            value="<%= (formData && formData.name) ? formData.name : '' %>" class="sw-input" />
        </div>
        <div>
          <label class="sw-label">Mobile Number</label>
          <input type="tel" name="mobile" placeholder="10-digit phone" pattern="[0-9]{10}" required
            value="<%= (formData && formData.mobile) ? formData.mobile : '' %>" class="sw-input" />
        </div>
        <div>
          <label class="sw-label">Password</label>
          <input type="password" name="password" placeholder="Min. 6 characters" required minlength="6" class="sw-input" />
        </div>
        <button type="submit" class="sw-btn sw-btn-primary w-full py-3 text-base">🚴 Register Now</button>
      </form>

      <div class="flex items-center gap-3 my-5">
        <div class="flex-1 h-px bg-gray-200"></div><span class="text-xs text-gray-400 font-semibold">OR</span><div class="flex-1 h-px bg-gray-200"></div>
      </div>

      <a href="/auth/google?role=delivery" class="sw-btn sw-btn-outline w-full py-2.5 text-sm gap-2">
        <svg class="w-5 h-5" viewBox="0 0 48 48"><g><path fill="#4285F4" d="M24 9.5c3.54 0 6.4 1.49 8.35 2.73L38.77 7.38C34.94 4.51 29.91 2.5 24 2.5c-9.02 0-16.56 5.32-20.63 13.73l8.6 6.69C14.24 16.52 19.35 9.5 24 9.5z"/><path fill="#34A853" d="M46.15 24.48c0-2.22-.18-4.35-.51-6.42H24v12.11h12.48c-.54 2.76-2.16 5.11-4.09 6.7l8.1 6.28C43.69 38.92 46.15 32.16 46.15 24.48z"/><path fill="#FBBC05" d="M12.97 28.92c-.68-2.06-1.07-4.24-1.07-6.41s.39-4.35 1.05-6.42L4.35 9.22C2.38 12.25 1.26 15.89 1.26 19.8s1.1 7.55 3.08 10.58l8.63-6.9z"/><path fill="#EA4335" d="M24 46.5c5.17 0 9.57-1.71 12.76-4.64l-8.1-6.28c-2.27 1.53-5.18 2.4-8.66 2.4-6.04 0-11.15-3.93-13.1-9.39l-8.63 6.9C6.43 40.18 14.97 46.5 24 46.5z"/></g></svg>
        Sign up with Google
      </a>

      <p class="text-center text-sm text-gray-500 mt-5">
        Already registered? <a href="/delivery/login" class="text-green-600 font-semibold hover:underline">Login →</a>
      </p>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
