<footer class="bg-gradient-to-br from-green-900 via-green-800 to-gray-900 text-gray-200 mt-20">
  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-6 pt-14 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="md:col-span-1 anim-fade-up">
        <a href="/" class="flex items-center gap-1 mb-4 group w-fit">
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-green-500 text-white text-xl mr-1 group-hover:scale-110 transition-transform">🥬</span>
          <span style="font-family:'Syne',sans-serif;font-weight:800" class="text-2xl text-white leading-none">Sabji</span>
          <span style="font-family:'Syne',sans-serif;font-weight:800" class="text-2xl text-yellow-400 leading-none">wala</span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed max-w-xs">
          Farm-fresh vegetables & daily essentials delivered to your doorstep. Supporting local vendors since 2025.
        </p>
        <div class="flex items-center gap-2 mt-4">
          <span class="inline-flex items-center px-2.5 py-1 bg-yellow-500/20 text-yellow-400 text-xs font-bold rounded-lg border border-yellow-500/30">ESTD 2025</span>
          <span class="inline-flex items-center px-2.5 py-1 bg-green-500/20 text-green-400 text-xs font-bold rounded-lg border border-green-500/30">🌱 Fresh Daily</span>
        </div>
      </div>

      <!-- Links -->
      <div class="anim-fade-up delay-100">
        <h3 style="font-family:'Syne',sans-serif" class="font-bold text-sm uppercase tracking-widest text-yellow-400 mb-5">Quick Links</h3>
        <ul class="space-y-2.5">
          <% [['/', 'Home'], ['/categories', 'All Categories'], ['/about', 'About Us'], ['/contact', 'Contact'], ['/privacy', 'Privacy Policy']].forEach(([href, label]) => { %>
            <li><a href="<%= href %>" class="text-gray-400 hover:text-white text-sm transition-colors flex items-center gap-1.5 group"><span class="w-1 h-1 rounded-full bg-green-500 group-hover:bg-yellow-400 transition-colors flex-shrink-0"></span><%= label %></a></li>
          <% }) %>
        </ul>
      </div>

      <!-- Partners -->
      <div class="anim-fade-up delay-200">
        <h3 style="font-family:'Syne',sans-serif" class="font-bold text-sm uppercase tracking-widest text-yellow-400 mb-5">Join Us</h3>
        <ul class="space-y-2.5">
          <% [
            ['/become-seller', '🛒 Become a Seller'],
            ['/delivery/signup', '🚴 Become Delivery Guy'],
            ['/seller/login', '📊 Seller Dashboard'],
            ['/coupons', '🎟️ Coupons & Offers'],
            ['/help-center', '❓ Help Centre'],
          ].forEach(([href, label]) => { %>
            <li><a href="<%= href %>" class="text-gray-400 hover:text-white text-sm transition-colors flex items-center gap-1.5"><%= label %></a></li>
          <% }) %>
        </ul>
      </div>

      <!-- Contact + Social -->
      <div class="anim-fade-up delay-300">
        <h3 style="font-family:'Syne',sans-serif" class="font-bold text-sm uppercase tracking-widest text-yellow-400 mb-5">Contact Us</h3>
        <ul class="space-y-3 text-sm text-gray-400">
          <li class="flex items-start gap-2">
            <span class="text-green-400 mt-0.5">📧</span>
            <a href="mailto:support@sabjiwala.com" class="hover:text-white transition-colors">support@sabjiwala.com</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-400 mt-0.5">📞</span>
            <a href="tel:+919876543210" class="hover:text-white transition-colors">+91 9876543210</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-400 mt-0.5">📍</span>
            <span>123 Sabjiwala Street, City, India</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-400 mt-0.5">🕐</span>
            <span>Mon–Sat, 9 AM – 7 PM</span>
          </li>
        </ul>
        <!-- Social -->
        <div class="flex gap-3 mt-5">
          <% [
            ['#', 'Instagram', 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z'],
            ['#', 'Facebook', 'M22 12a10 10 0 1 0-11.5 9.87v-6.98h-2.54v-2.89h2.54V9.46c0-2.5 1.49-3.89 3.78-3.89 1.1 0 2.25.2 2.25.2v2.48h-1.27c-1.26 0-1.65.78-1.65 1.58v1.9h2.81l-.45 2.89h-2.36v6.98A10 10 0 0 0 22 12z'],
          ].forEach(([href, name, path]) => { %>
            <a href="<%= href %>" aria-label="<%= name %>" rel="nofollow noopener"
               class="w-9 h-9 rounded-xl bg-white/10 flex items-center justify-center hover:bg-green-600 transition-colors group">
              <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 text-gray-400 group-hover:text-white"><path d="<%= path %>"/></svg>
            </a>
          <% }) %>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-gray-500">&copy; 2025 <span style="font-family:'Syne',sans-serif" class="text-white font-bold">Sabjiwala</span>. All rights reserved.</p>
      <p class="text-xs text-gray-500">Made with 🥬 for fresh India</p>
    </div>
  </div>
</footer>
