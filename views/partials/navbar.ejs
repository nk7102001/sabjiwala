<nav class="bg-white/95 backdrop-blur-md shadow-sm sticky top-0 z-50 border-b border-green-50"
     x-data="{ mobileMenuOpen: false }"
     x-init="$watch('mobileMenuOpen', v => { document.body.style.overflow = v ? 'hidden' : '' })"
     @keydown.escape.stop="mobileMenuOpen = false">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-1 select-none group" @click.stop>
        <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-green-600 text-white text-lg mr-1 group-hover:rotate-6 transition-transform duration-300">🥬</span>
        <span style="font-family:'Syne',sans-serif;font-weight:800" class="text-2xl text-green-700 leading-none">Sabji</span>
        <span style="font-family:'Syne',sans-serif;font-weight:800" class="text-2xl text-yellow-500 leading-none">wala</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex space-x-6 font-medium text-gray-700 items-center">
        <a href="/" class="relative group py-1 text-sm font-semibold text-gray-700 hover:text-green-600 transition-colors" @click.stop>
          Home<span class="absolute left-0 -bottom-0.5 w-0 group-hover:w-full h-0.5 bg-green-500 rounded transition-all duration-300"></span>
        </a>
        <div class="relative" x-data="{ open: false }" @mouseleave="open = false">
          <button @mouseenter="open = true" @focus="open = true" @click.stop
            class="inline-flex items-center gap-1 py-1 text-sm font-semibold text-gray-700 hover:text-green-600 transition-colors"
            :aria-expanded="open.toString()">
            Categories
            <svg class="w-4 h-4 text-gray-400 transition-transform duration-300" :class="{'rotate-180': open}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div x-show="open" x-transition class="absolute left-0 mt-3 w-56 rounded-2xl shadow-xl bg-white border border-green-50 z-40 overflow-hidden" style="display:none" @pointerdown.stop>
            <div class="py-2 max-h-60 overflow-auto">
              <% const _cats = (typeof sabjiCategories !== 'undefined' && Array.isArray(sabjiCategories)) ? sabjiCategories : []; %>
              <% _cats.forEach((cat) => { %>
                <a href="/products/<%= cat.slug %>" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-green-50 hover:text-green-700 transition-colors" @click.stop>
                  <span class="w-1.5 h-1.5 rounded-full bg-green-400 flex-shrink-0"></span><%= cat.name %>
                </a>
              <% }) %>
              <div class="border-t border-gray-100 my-1"></div>
              <a href="/categories" class="flex items-center gap-2 px-4 py-2.5 text-sm font-bold text-green-700 hover:bg-green-50 transition-colors" @click.stop>🌿 All Categories</a>
            </div>
          </div>
        </div>
        <a href="/cart" class="relative flex items-center gap-1.5 py-1 text-sm font-semibold text-gray-700 hover:text-green-600 transition-colors group" @click.stop>
          <span class="relative">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4"></path><circle cx="7.5" cy="17.5" r="1.5"/><circle cx="16.5" cy="17.5" r="1.5"/></svg>
            <span id="cart-count" class="absolute -top-2 -right-2 bg-red-500 text-white text-[10px] font-bold w-4 h-4 hidden items-center justify-center rounded-full">0</span>
          </span>
          Cart<span class="absolute left-0 -bottom-0.5 w-0 group-hover:w-full h-0.5 bg-green-500 rounded transition-all duration-300"></span>
        </a>
        <% if (user) { %>
          <div class="relative" x-data="{ open: false }" @mouseleave="open = false">
            <button @click.stop="open = !open" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl bg-green-50 border border-green-200 text-sm font-semibold text-green-700 hover:bg-green-100 transition" :aria-expanded="open.toString()">
              <span class="w-6 h-6 rounded-full bg-green-600 text-white flex items-center justify-center text-xs font-black"><%= user.name ? user.name[0].toUpperCase() : 'U' %></span>
              My Account
              <svg class="w-4 h-4 text-green-500 transition-transform" :class="{'rotate-180': open}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div x-show="open" x-transition class="absolute right-0 mt-3 w-52 rounded-2xl shadow-xl bg-white border border-green-50 z-50 overflow-hidden" style="display:none" @pointerdown.stop>
              <div class="p-2">
                <a href="/orders" class="flex items-center gap-2 px-3 py-2.5 text-sm text-gray-700 hover:bg-green-50 rounded-xl transition" @click.stop>📦 My Orders</a>
                <a href="/profile/edit" class="flex items-center gap-2 px-3 py-2.5 text-sm text-gray-700 hover:bg-green-50 rounded-xl transition" @click.stop>✏️ Edit Profile</a>
                <a href="/coupons" class="flex items-center gap-2 px-3 py-2.5 text-sm text-gray-700 hover:bg-green-50 rounded-xl transition" @click.stop>🎟️ Coupons</a>
                <a href="/help-center" class="flex items-center gap-2 px-3 py-2.5 text-sm text-gray-700 hover:bg-green-50 rounded-xl transition" @click.stop>❓ Help Centre</a>
                <a href="/address/saved" class="flex items-center gap-2 px-3 py-2.5 text-sm text-gray-700 hover:bg-green-50 rounded-xl transition" @click.stop>📍 Saved Address</a>
                <div class="border-t border-gray-100 my-1"></div>
                <a href="/logout" class="flex items-center gap-2 px-3 py-2.5 text-sm text-red-600 hover:bg-red-50 rounded-xl transition font-semibold" @click.stop>🚪 Logout</a>
              </div>
            </div>
          </div>
        <% } else { %>
          <a href="/login" class="sw-btn sw-btn-primary px-4 py-1.5 text-sm" @click.stop>Login</a>
        <% } %>
      </div>

      <!-- Burger -->
      <button type="button" @click.stop="mobileMenuOpen = !mobileMenuOpen" class="md:hidden flex items-center justify-center w-10 h-10 rounded-xl hover:bg-green-50 transition" aria-label="Toggle menu">
        <svg class="w-6 h-6 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path :class="{'hidden': mobileMenuOpen}" class="inline-flex" d="M4 6h16M4 12h16M4 18h16"/>
          <path :class="{'hidden': !mobileMenuOpen, 'inline-flex': mobileMenuOpen}" class="hidden" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div x-show="mobileMenuOpen" x-transition class="fixed top-16 left-0 right-0 z-50 bg-white md:hidden border-t border-green-50 shadow-xl overflow-y-auto max-h-[80vh]" style="display:none" @click.outside="mobileMenuOpen = false" @pointerdown.stop>
    <div class="flex flex-col py-4 px-4 space-y-1">
      <a href="/" class="flex items-center gap-2 py-2.5 px-3 rounded-xl hover:bg-green-50 text-gray-700 font-medium" @click="mobileMenuOpen=false">🏠 Home</a>
      <div x-data="{ openCat: false }">
        <button @click="openCat = !openCat" class="flex items-center justify-between w-full py-2.5 px-3 rounded-xl hover:bg-green-50 text-gray-700 font-medium">
          <span>🌿 Categories</span>
          <svg class="w-4 h-4 transition-transform" :class="{'rotate-180': openCat}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div x-show="openCat" class="pl-4 py-1 space-y-0.5" style="display:none">
          <% const _mcats = (typeof sabjiCategories !== 'undefined' && Array.isArray(sabjiCategories)) ? sabjiCategories : []; %>
          <% _mcats.forEach((cat) => { %>
            <a href="/products/<%= cat.slug %>" class="flex items-center gap-2 py-2 px-3 rounded-lg hover:bg-green-50 text-sm text-gray-700" @click="mobileMenuOpen=false"><span class="w-1.5 h-1.5 rounded-full bg-green-400"></span><%= cat.name %></a>
          <% }) %>
          <a href="/categories" class="flex items-center gap-2 py-2 px-3 rounded-lg font-bold text-green-700 hover:bg-green-50 text-sm" @click="mobileMenuOpen=false">All Categories →</a>
        </div>
      </div>
      <a href="/cart" class="flex items-center gap-2 py-2.5 px-3 rounded-xl hover:bg-green-50 text-gray-700 font-medium" @click="mobileMenuOpen=false">🛒 Cart <span id="cart-count-mobile" class="ml-1 bg-red-500 text-white text-[10px] font-bold w-4 h-4 hidden items-center justify-center rounded-full">0</span></a>
      <% if (user) { %>
        <div class="border-t border-gray-100 my-1 pt-1">
          <a href="/orders" class="flex items-center gap-2 py-2.5 px-3 rounded-xl hover:bg-green-50 text-gray-700 font-medium" @click="mobileMenuOpen=false">📦 My Orders</a>
          <a href="/profile/edit" class="flex items-center gap-2 py-2.5 px-3 rounded-xl hover:bg-green-50 text-gray-700 font-medium" @click="mobileMenuOpen=false">✏️ Edit Profile</a>
          <a href="/coupons" class="flex items-center gap-2 py-2.5 px-3 rounded-xl hover:bg-green-50 text-gray-700 font-medium" @click="mobileMenuOpen=false">🎟️ Coupons</a>
          <a href="/address/saved" class="flex items-center gap-2 py-2.5 px-3 rounded-xl hover:bg-green-50 text-gray-700 font-medium" @click="mobileMenuOpen=false">📍 Saved Address</a>
          <a href="/logout" class="flex items-center gap-2 py-2.5 px-3 rounded-xl hover:bg-red-50 text-red-600 font-semibold mt-1" @click="mobileMenuOpen=false">🚪 Logout</a>
        </div>
      <% } else { %>
        <a href="/login" class="sw-btn sw-btn-primary w-full py-2.5 mt-2 text-sm text-center" @click="mobileMenuOpen=false">Login / Sign Up</a>
      <% } %>
    </div>
  </div>
</nav>
<script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
<script>
  function updateCartCount() {
    let cart = [];
    try { cart = JSON.parse(localStorage.getItem("cart") || "[]"); if (!Array.isArray(cart)) cart = []; } catch { cart = []; }
    const total = cart.reduce((s, i) => s + (parseInt(i.qty, 10) || 0), 0);
    document.querySelectorAll("#cart-count, #cart-count-mobile").forEach(el => {
      el.textContent = total;
      if (total > 0) { el.classList.remove("hidden"); el.style.display = "flex"; }
      else { el.classList.add("hidden"); el.style.display = "none"; }
    });
  }
  document.addEventListener("DOMContentLoaded", updateCartCount);
  window.addEventListener("cartUpdated", updateCartCount);
</script>
