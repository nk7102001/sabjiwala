<%/* Shared <head> partial - include at top of every page */%>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
<style>
  :root {
    --green-primary: #16a34a;
    --green-dark: #15803d;
    --green-light: #bbf7d0;
    --yellow-accent: #eab308;
    --yellow-light: #fef9c3;
    --bg-page: #f0fdf4;
    --text-dark: #1a2e1a;
    --text-muted: #4b7a4b;
    --card-bg: #ffffff;
    --border-soft: #d1fae5;
    --shadow-card: 0 4px 24px rgba(22,163,74,0.10);
    --shadow-hover: 0 8px 40px rgba(22,163,74,0.18);
    --radius-card: 1.25rem;
    --radius-btn: 0.75rem;
  }

  *, *::before, *::after { box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg-page);
    color: var(--text-dark);
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3, h4 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
  }

  /* ─── Scrollbar ─── */
  ::-webkit-scrollbar { width: 7px; height: 7px; }
  ::-webkit-scrollbar-thumb { background: var(--green-primary); border-radius: 99px; }
  ::-webkit-scrollbar-track { background: var(--green-light); }

  /* ─── Animations ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; } to { opacity: 1; }
  }
  @keyframes scaleIn {
    from { opacity: 0; transform: scale(0.92); }
    to   { opacity: 1; transform: scale(1); }
  }
  @keyframes slideRight {
    from { opacity: 0; transform: translateX(-24px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes float {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
  }
  @keyframes pulse-ring {
    0%   { box-shadow: 0 0 0 0 rgba(22,163,74,.35); }
    70%  { box-shadow: 0 0 0 12px rgba(22,163,74,0); }
    100% { box-shadow: 0 0 0 0 rgba(22,163,74,0); }
  }
  @keyframes shimmer {
    0%   { background-position: -400px 0; }
    100% { background-position: 400px 0; }
  }
  @keyframes toastIn {
    from { opacity: 0; transform: translateY(20px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes bounceIn {
    0%   { transform: scale(0.3); opacity: 0; }
    50%  { transform: scale(1.05); }
    70%  { transform: scale(0.95); }
    100% { transform: scale(1); opacity: 1; }
  }

  /* ─── Utility animation classes ─── */
  .anim-fade-up   { animation: fadeUp   0.55s cubic-bezier(.22,1,.36,1) both; }
  .anim-fade-in   { animation: fadeIn   0.45s ease both; }
  .anim-scale-in  { animation: scaleIn  0.45s cubic-bezier(.22,1,.36,1) both; }
  .anim-slide-r   { animation: slideRight 0.5s cubic-bezier(.22,1,.36,1) both; }
  .anim-float     { animation: float 3.5s ease-in-out infinite; }
  .anim-bounce-in { animation: bounceIn 0.6s cubic-bezier(.22,1,.36,1) both; }

  .delay-100 { animation-delay: .1s; }
  .delay-150 { animation-delay: .15s; }
  .delay-200 { animation-delay: .2s; }
  .delay-250 { animation-delay: .25s; }
  .delay-300 { animation-delay: .3s; }
  .delay-400 { animation-delay: .4s; }
  .delay-500 { animation-delay: .5s; }

  /* ─── Card ─── */
  .sw-card {
    background: var(--card-bg);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--border-soft);
    transition: box-shadow .25s, transform .25s;
  }
  .sw-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-3px);
  }

  /* ─── Buttons ─── */
  .sw-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: .45rem;
    border-radius: var(--radius-btn);
    font-family: 'DM Sans', sans-serif; font-weight: 600;
    transition: background .2s, transform .15s, box-shadow .2s;
    cursor: pointer; border: none; text-decoration: none;
  }
  .sw-btn:active { transform: scale(.97); }

  .sw-btn-primary {
    background: var(--green-primary);
    color: #fff;
    box-shadow: 0 2px 12px rgba(22,163,74,.3);
  }
  .sw-btn-primary:hover {
    background: var(--green-dark);
    box-shadow: 0 4px 20px rgba(22,163,74,.4);
    transform: translateY(-1px);
  }

  .sw-btn-yellow {
    background: var(--yellow-accent);
    color: #1a1a1a;
    box-shadow: 0 2px 12px rgba(234,179,8,.3);
  }
  .sw-btn-yellow:hover {
    background: #ca8a04;
    transform: translateY(-1px);
  }

  .sw-btn-outline {
    background: transparent;
    border: 2px solid var(--green-primary);
    color: var(--green-primary);
  }
  .sw-btn-outline:hover {
    background: var(--green-primary);
    color: #fff;
  }

  .sw-btn-danger {
    background: #dc2626; color: #fff;
    box-shadow: 0 2px 10px rgba(220,38,38,.25);
  }
  .sw-btn-danger:hover { background: #b91c1c; }

  /* ─── Input ─── */
  .sw-input {
    width: 100%; padding: .7rem 1rem;
    border: 1.5px solid #d1fae5;
    border-radius: .75rem;
    font-family: 'DM Sans', sans-serif;
    font-size: .95rem;
    background: #f8fff8;
    color: var(--text-dark);
    transition: border-color .2s, box-shadow .2s;
    outline: none;
  }
  .sw-input:focus {
    border-color: var(--green-primary);
    box-shadow: 0 0 0 3px rgba(22,163,74,.15);
    background: #fff;
  }
  .sw-input::placeholder { color: #86a886; }

  .sw-label {
    display: block; font-weight: 600; margin-bottom: .35rem;
    font-size: .875rem; color: #2d572d;
    font-family: 'DM Sans', sans-serif;
  }

  /* ─── Badge ─── */
  .sw-badge {
    display: inline-flex; align-items: center; gap: .25rem;
    padding: .2rem .65rem; border-radius: 99px;
    font-size: .72rem; font-weight: 700; letter-spacing: .03em;
    font-family: 'Syne', sans-serif;
  }
  .sw-badge-green  { background: #dcfce7; color: #16a34a; }
  .sw-badge-yellow { background: #fef9c3; color: #a16207; }
  .sw-badge-red    { background: #fee2e2; color: #dc2626; }
  .sw-badge-blue   { background: #dbeafe; color: #1d4ed8; }

  /* ─── Alert ─── */
  .sw-alert {
    padding: .85rem 1.1rem; border-radius: .875rem;
    font-size: .9rem; font-weight: 500;
    display: flex; align-items: flex-start; gap: .6rem;
    animation: fadeUp .4s ease both;
  }
  .sw-alert-success { background: #dcfce7; color: #15803d; border-left: 4px solid #16a34a; }
  .sw-alert-error   { background: #fee2e2; color: #b91c1c; border-left: 4px solid #dc2626; }

  /* ─── Page wrapper ─── */
  .sw-page {
    min-height: 100vh; display: flex; flex-direction: column;
  }
  .sw-main {
    flex: 1;
  }

  /* ─── Section heading ─── */
  .sw-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    color: var(--green-primary);
    position: relative;
    display: inline-block;
  }
  .sw-heading::after {
    content: '';
    display: block;
    height: 4px;
    background: var(--yellow-accent);
    border-radius: 99px;
    margin-top: 4px;
    width: 40%;
    transition: width .4s;
  }
  .sw-heading:hover::after { width: 100%; }

  /* ─── Hero gradient bg ─── */
  .sw-hero-bg {
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 50%, #fef9c3 100%);
  }

  /* ─── Toast ─── */
  .sw-toast {
    position: fixed; bottom: 1.5rem; right: 1.5rem;
    background: #15803d; color: #fff;
    padding: .85rem 1.4rem; border-radius: 1rem;
    font-family: 'DM Sans', sans-serif; font-weight: 600;
    font-size: .9rem;
    box-shadow: 0 8px 30px rgba(21,128,61,.35);
    z-index: 9999;
    animation: toastIn .35s cubic-bezier(.22,1,.36,1);
    display: flex; align-items: center; gap: .5rem;
  }

  /* ─── Star rating ─── */
  .sw-stars { color: #f59e0b; letter-spacing: .05em; }

  /* ─── Table ─── */
  .sw-table { width: 100%; border-collapse: collapse; }
  .sw-table th {
    background: #dcfce7; color: #15803d;
    padding: .75rem 1rem; text-align: left;
    font-family: 'Syne', sans-serif; font-size: .82rem; letter-spacing: .06em; text-transform: uppercase;
  }
  .sw-table td { padding: .75rem 1rem; border-bottom: 1px solid #f0fdf4; }
  .sw-table tr:hover td { background: #f0fdf4; }
  .sw-table tr:last-child td { border-bottom: none; }

  /* ─── Qty stepper ─── */
  .sw-stepper {
    display: flex; align-items: center; gap: .5rem;
  }
  .sw-stepper-btn {
    width: 2rem; height: 2rem; border-radius: .5rem;
    background: #dcfce7; color: #15803d;
    border: none; font-size: 1.1rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background .2s, transform .15s;
  }
  .sw-stepper-btn:hover { background: #bbf7d0; transform: scale(1.1); }
  .sw-stepper-input {
    width: 3.5rem; text-align: center; padding: .35rem .5rem;
    border: 1.5px solid #d1fae5; border-radius: .5rem;
    font-family: 'DM Sans', sans-serif; font-weight: 600;
  }

  /* ─── Loading skeleton ─── */
  .sw-skeleton {
    background: linear-gradient(90deg, #dcfce7 25%, #bbf7d0 50%, #dcfce7 75%);
    background-size: 400px 100%;
    animation: shimmer 1.2s infinite linear;
    border-radius: .75rem;
  }
</style>
