<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>All Orders — Admin</title>
</head>
<body class="sw-page" style="background:#f0fdf4">
  <!-- Admin Topbar -->
<nav class="bg-gray-900 text-white px-6 py-3 flex items-center justify-between sticky top-0 z-50">
  <a href="/admin/dashboard" class="flex items-center gap-2">
    <span class="text-xl">🛡️</span>
    <span style="font-family:'Syne',sans-serif;font-weight:800" class="text-lg">Sabjiwala <span class="text-green-400">Admin</span></span>
  </a>
  <div class="flex flex-wrap gap-2">
    <a href="/admin/reports" class="bg-purple-600 hover:bg-purple-700 text-white px-3 py-1.5 rounded-lg text-xs font-semibold transition">📊 Reports</a>
    <a href="/admin/sellers" class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded-lg text-xs font-semibold transition">🛒 Sellers</a>
    <a href="/admin/users" class="bg-teal-600 hover:bg-teal-700 text-white px-3 py-1.5 rounded-lg text-xs font-semibold transition">👥 Users</a>
    <a href="/admin/orders" class="bg-orange-600 hover:bg-orange-700 text-white px-3 py-1.5 rounded-lg text-xs font-semibold transition">📦 Orders</a>
  </div>
</nav>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="sw-heading text-2xl mb-6 anim-fade-up">📦 All Orders</h1>

    <% const _orders = Array.isArray(orders) ? orders : []; %>
    <% if (_orders.length === 0) { %>
      <div class="sw-card p-10 text-center"><p class="text-gray-400">No orders found.</p></div>
    <% } else { %>
      <div class="space-y-4">
        <% _orders.forEach((order, i) => { %>
          <div class="sw-card overflow-hidden anim-fade-up" style="animation-delay:<%=i*0.05%>s">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 px-5 py-3 bg-green-50 border-b border-green-100">
              <div>
                <span class="font-mono text-xs text-gray-400">Order ID: </span>
                <span class="font-bold text-sm text-gray-700"><%= order._id %></span>
              </div>
              <div class="flex items-center gap-2 flex-wrap">
                <span class="sw-badge <%=order.status==='Delivered'?'sw-badge-green':order.status==='Cancelled'?'sw-badge-red':'sw-badge-yellow'%>"><%= order.status||'Pending' %></span>
                <span class="text-xs text-gray-400"><%= order.createdAt ? new Date(order.createdAt).toLocaleString() : '' %></span>
                <form action="/admin/orders/<%= order._id %>/status" method="POST" class="inline">
                  <select name="status" onchange="this.form.submit()" class="text-xs border border-gray-300 rounded-lg px-2 py-1 bg-white focus:outline-none focus:ring-1 focus:ring-green-400">
                    <% ['Pending','Processing','Packed','Assigned','Delivered','Cancelled'].forEach(s => { %>
                      <option value="<%= s %>" <%=order.status===s?'selected':''%>><%= s %></option>
                    <% }) %>
                  </select>
                </form>
              </div>
            </div>
            <div class="px-5 py-3 grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
              <div><p class="text-xs text-gray-400 uppercase tracking-wide">Customer</p><p class="font-semibold"><%= (order.guestInfo&&order.guestInfo.name)||(order.user&&order.user.name)||'Guest' %></p></div>
              <div><p class="text-xs text-gray-400 uppercase tracking-wide">Total</p><p class="font-black text-green-700">₹<%= Number(order.total||0) %></p></div>
              <div><p class="text-xs text-gray-400 uppercase tracking-wide">Payment</p><p class="font-semibold"><%= order.paymentMethod||'COD' %></p></div>
              <div><p class="text-xs text-gray-400 uppercase tracking-wide">Pay Status</p>
                <span class="sw-badge <%=order.paymentStatus==='Paid'?'sw-badge-green':'sw-badge-yellow'%>"><%= order.paymentStatus||'Unpaid' %></span>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
</body>
</html>
