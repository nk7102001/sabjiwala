<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Seller Management — Admin</title>
</head>
<body class="sw-page" style="background:#f0fdf4">
  <nav class="bg-gray-900 text-white px-6 py-3 flex items-center justify-between sticky top-0 z-50">
    <a href="/admin/dashboard" style="font-family:'Syne',sans-serif;font-weight:800" class="text-lg">Sabjiwala <span class="text-green-400">Admin</span></a>
    <div class="flex gap-2">
      <a href="/admin/dashboard" class="bg-green-600 hover:bg-green-700 text-white px-3 py-1.5 rounded-lg text-xs font-semibold transition">🏠 Dashboard</a>
      <a href="/admin/users" class="bg-teal-600 hover:bg-teal-700 text-white px-3 py-1.5 rounded-lg text-xs font-semibold transition">👥 Users</a>
      <a href="/admin/orders" class="bg-orange-600 hover:bg-orange-700 text-white px-3 py-1.5 rounded-lg text-xs font-semibold transition">📦 Orders</a>
    </div>
  </nav>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center gap-3 mb-6 anim-fade-up">
      <span class="text-3xl">🛒</span>
      <h1 class="sw-heading text-2xl">All Sellers</h1>
    </div>
    <div class="sw-card overflow-hidden anim-fade-up delay-100">
      <div class="overflow-x-auto">
        <table class="sw-table min-w-[700px]">
          <thead><tr><th>Shop</th><th>Owner</th><th>City</th><th>Business</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody>
            <% const _sellers = Array.isArray(sellers) ? sellers : []; %>
            <% if (_sellers.length === 0) { %>
              <tr><td colspan="6" class="text-center py-10 text-gray-400">No sellers found.</td></tr>
            <% } else { %>
              <% _sellers.forEach(s => { %>
                <tr>
                  <td>
                    <div class="flex items-center gap-2">
                      <% if (s.shopPhoto) { %>
                        <img src="<%= s.shopPhoto %>" class="w-8 h-8 rounded-lg object-cover flex-shrink-0" />
                      <% } else { %>
                        <div class="w-8 h-8 rounded-lg bg-green-100 flex items-center justify-center text-sm flex-shrink-0">🏪</div>
                      <% } %>
                      <span class="font-semibold text-sm"><%= s.shopName||'' %></span>
                    </div>
                  </td>
                  <td class="text-sm"><%= s.name||'' %></td>
                  <td class="text-gray-500 text-sm"><%= s.city||'—' %></td>
                  <td class="text-gray-500 text-sm"><%= s.businessType||'—' %></td>
                  <td><span class="sw-badge <%=s.status==='Approved'?'sw-badge-green':s.status==='Rejected'?'sw-badge-red':'sw-badge-yellow'%>"><%= s.status||'Pending' %></span></td>
                  <td>
                    <div class="flex gap-1.5">
                      <a href="/admin/seller/<%= s._id %>" class="sw-btn sw-btn-outline px-2.5 py-1.5 text-xs">View</a>
                      <% if (s.status !== 'Approved') { %>
                        <form action="/admin/sellers/<%= s._id %>/approve" method="POST">
                          <button class="sw-btn sw-btn-primary px-2.5 py-1.5 text-xs">✅</button>
                        </form>
                      <% } %>
                      <% if (s.status !== 'Rejected') { %>
                        <form action="/admin/sellers/<%= s._id %>/reject" method="POST">
                          <button class="sw-btn sw-btn-danger px-2.5 py-1.5 text-xs">❌</button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</body>
</html>
