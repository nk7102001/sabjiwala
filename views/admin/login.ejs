<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Admin Login — Sabjiwala</title>
</head>
<body class="sw-page" style="background: linear-gradient(135deg,#1a2e1a 0%,#15803d 100%); min-height:100vh;">
  <main class="flex min-h-screen items-center justify-center px-4 py-16">
    <div class="sw-card w-full max-w-sm p-8 anim-scale-in">
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gray-900 text-3xl mb-3 anim-bounce-in">🛡️</div>
        <h1 class="sw-heading text-xl text-center">Admin Portal</h1>
        <p class="text-gray-500 text-sm mt-1">Restricted access</p>
      </div>
      <% if (typeof error !== 'undefined') { %>
        <div class="sw-alert sw-alert-error mb-5">⚠️ <%= error %></div>
      <% } %>
      <form method="POST" class="space-y-4">
        <div>
          <label class="sw-label">Username</label>
          <input type="text" name="username" placeholder="admin" required autofocus class="sw-input" />
        </div>
        <div>
          <label class="sw-label">Password</label>
          <input type="password" name="password" placeholder="••••••••" required class="sw-input" />
        </div>
        <button type="submit" class="sw-btn sw-btn-primary w-full py-3">🔐 Login</button>
      </form>
    </div>
  </main>
</body>
</html>
