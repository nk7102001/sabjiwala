<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Coupons & Offers — Sabjiwala</title>
</head>
<body class="sw-page">
  <%- include('partials/navbar') %>
  <main class="sw-main max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="text-center mb-10 anim-fade-up">
      <span class="text-5xl block mb-4">🎟️</span>
      <h1 class="sw-heading text-3xl sm:text-4xl mx-auto mb-2">Coupons & Offers</h1>
      <p class="text-gray-500 text-base">Save more on your fresh vegetable orders!</p>
    </div>

    <% if (!coupons || coupons.length === 0) { %>
      <div class="sw-card p-12 text-center anim-scale-in">
        <div class="text-5xl mb-4">😢</div>
        <h3 style="font-family:'Syne',sans-serif" class="text-xl font-bold text-gray-600 mb-2">No Coupons Available</h3>
        <p class="text-gray-400">Check back soon for exciting offers!</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <% coupons.forEach((coupon, i) => { %>
          <div class="relative overflow-hidden anim-fade-up" style="animation-delay:<%=i*0.09%>s">
            <!-- Coupon Card -->
            <div class="bg-white rounded-2xl shadow-md border border-green-100 overflow-hidden flex">
              <!-- Left colored strip -->
              <div class="w-16 flex-shrink-0 flex flex-col items-center justify-center py-4 text-white text-center"
                   style="background: linear-gradient(180deg,#16a34a,#15803d)">
                <span class="text-2xl"><%= coupon.discountType === 'percentage' ? '%' : '₹' %></span>
                <span class="text-2xl font-black" style="font-family:'Syne',sans-serif"><%= coupon.discountValue %></span>
                <span class="text-[10px] font-semibold opacity-80 uppercase tracking-wide">OFF</span>
              </div>
              <!-- Content -->
              <div class="flex-1 p-5 relative">
                <!-- Scissor dashes -->
                <div class="absolute left-0 top-0 bottom-0 w-px border-l-2 border-dashed border-green-200"></div>
                <div class="pl-3">
                  <div class="flex items-start justify-between gap-2 mb-2">
                    <h3 class="font-black text-xl text-gray-800 tracking-wider" style="font-family:'Syne',sans-serif;letter-spacing:.08em">
                      <%= coupon.code %>
                    </h3>
                    <button onclick="copyCode('<%= coupon.code %>')"
                      class="sw-btn bg-green-50 text-green-700 border border-green-200 px-2.5 py-1.5 text-xs hover:bg-green-100 transition flex-shrink-0">
                      📋 Copy
                    </button>
                  </div>
                  <p class="text-gray-500 text-sm mb-3"><%= coupon.description || 'Exclusive discount coupon' %></p>
                  <div class="flex items-center justify-between">
                    <span class="sw-badge sw-badge-green text-xs">
                      <%= coupon.discountType === 'percentage' ? `${coupon.discountValue}% off` : `₹${coupon.discountValue} off` %>
                    </span>
                    <span class="text-xs text-gray-400">
                      Valid till: <strong><%= coupon.expiryDate ? coupon.expiryDate.toLocaleDateString('en-IN') : 'N/A' %></strong>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include('partials/footer') %>
  <script>
    function copyCode(code) {
      navigator.clipboard.writeText(code).then(() => {
        const t = document.createElement('div');
        t.className = 'sw-toast';
        t.innerHTML = `🎟️ Coupon code <strong>${code}</strong> copied!`;
        document.body.appendChild(t);
        setTimeout(() => { t.style.opacity='0'; t.style.transition='opacity .3s'; setTimeout(()=>t.remove(),300); }, 2500);
      });
    }
  </script>
</body>
</html>
