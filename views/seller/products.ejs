<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>My Products — Sabjiwala Seller</title>
</head>
<body class="sw-page">
  <%- include('../partials/navbar') %>
  <main class="sw-main max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="flex items-center justify-between mb-8 anim-fade-up">
      <div class="flex items-center gap-3">
        <span class="text-3xl">📦</span>
        <h1 class="sw-heading text-2xl sm:text-3xl">My Products</h1>
      </div>
      <a href="/seller/products/add" class="sw-btn sw-btn-primary px-5 py-2.5 text-sm">➕ Add Product</a>
    </div>

    <% const _products = Array.isArray(products) ? products : []; %>
    <% if (_products.length === 0) { %>
      <div class="sw-card p-12 text-center anim-scale-in">
        <div class="text-5xl mb-4">📭</div>
        <h3 style="font-family:'Syne',sans-serif" class="text-xl font-bold text-gray-600 mb-2">No Products Yet</h3>
        <p class="text-gray-400 mb-6">Add your first product to start selling!</p>
        <a href="/seller/products/add" class="sw-btn sw-btn-primary px-6 py-2.5">➕ Add First Product</a>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        <% _products.forEach((p, i) => { %>
          <div class="sw-card overflow-hidden flex flex-col anim-fade-up" style="animation-delay:<%=i*0.06%>s">
            <div class="relative overflow-hidden bg-green-50 h-40">
              <% if (p.imageUrl) { %>
                <img src="<%= p.imageUrl %>" alt="<%= p.name||'Product' %>"
                  class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center text-5xl">🥦</div>
              <% } %>
            </div>
            <div class="p-4 flex flex-col flex-1">
              <h3 class="font-bold text-gray-800 mb-1 line-clamp-1" style="font-family:'Syne',sans-serif"><%= p.name||'Product' %></h3>
              <div class="flex items-center gap-2 mb-3">
                <span class="text-green-700 font-black">₹<%= p.pricePerKg!=null?p.pricePerKg:'N/A' %></span>
                <span class="text-gray-400 text-xs">/kg</span>
                <span class="sw-badge sw-badge-green ml-auto text-xs"><%= p.availableQty!=null?p.availableQty:'N/A' %> kg</span>
              </div>
              <div class="mt-auto flex gap-2">
                <a href="/seller/products/edit/<%= p._id %>" class="sw-btn sw-btn-outline flex-1 py-2 text-sm">✏️ Edit</a>
                <form action="/seller/products/delete/<%= p._id %>" method="POST" class="flex-1"
                      onsubmit="return confirm('Delete this product?')">
                  <button type="submit" class="sw-btn sw-btn-danger w-full py-2 text-sm">🗑️ Delete</button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
