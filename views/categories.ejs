<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>All Categories — Sabjiwala</title>
</head>
<body class="sw-page">
  <%- include('partials/navbar') %>
  <main class="sw-main max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="text-center mb-10 anim-fade-up">
      <span class="text-4xl block mb-3">🌿</span>
      <h1 class="sw-heading text-3xl sm:text-4xl mx-auto">All Categories</h1>
      <p class="text-gray-500 mt-2">Shop by your favourite sabzi category</p>
    </div>

    <% const _cats = Array.isArray(sabjiCategories) ? sabjiCategories : []; %>
    <% if (_cats.length === 0) { %>
      <p class="text-center text-gray-400 py-12">No categories available.</p>
    <% } else { %>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-5">
        <% _cats.forEach((cat, i) => { %>
          <a href="/products/<%= cat.slug %>"
             class="sw-card group overflow-hidden text-center anim-fade-up"
             style="animation-delay:<%=i*0.05%>s">
            <div class="aspect-[4/3] overflow-hidden bg-green-50">
              <img src="<%= cat.imageUrl %>" alt="<%= cat.name %>"
                class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-3">
              <h3 class="font-bold text-sm sm:text-base text-gray-800 group-hover:text-green-600 transition-colors" style="font-family:'Syne',sans-serif"><%= cat.name %></h3>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
