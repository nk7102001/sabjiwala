<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Your Cart — Sabjiwala</title>
</head>
<body class="sw-page">
  <%- include('partials/navbar') %>
  <main class="sw-main max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
    <div class="flex items-center gap-3 mb-8 anim-fade-up">
      <span class="text-3xl">🛒</span>
      <h1 class="sw-heading text-2xl sm:text-3xl">Your Cart</h1>
    </div>
    <div id="cart-container"></div>
  </main>
  <%- include('partials/footer') %>

  <script>
    const customerLoggedIn = "<%- (typeof customer !== 'undefined' && customer) ? 'true' : 'false' %>";

    function getCart() {
      try { const c = JSON.parse(localStorage.getItem("cart") || "[]"); return Array.isArray(c) ? c : []; }
      catch { localStorage.removeItem("cart"); return []; }
    }
    function saveCart(cart) { localStorage.setItem("cart", JSON.stringify(cart)); window.dispatchEvent(new Event("cartUpdated")); }
    function removeFromCart(i) { const c = getCart(); c.splice(i, 1); saveCart(c); renderCart(); }
    function updateQty(i, delta) {
      const c = getCart();
      c[i].qty = Math.max(1, (parseInt(c[i].qty)||1) + delta);
      saveCart(c); renderCart();
    }
    function prepareCartData() { const el = document.getElementById("cartData"); if (el) el.value = JSON.stringify(getCart()); }
    function clearCartAfterCheckout() { localStorage.removeItem("cart"); }

    function renderCart() {
      const container = document.getElementById("cart-container");
      const cart = getCart();
      if (!cart.length) {
        container.innerHTML = `
          <div class="sw-card p-12 text-center anim-scale-in">
            <div class="text-6xl mb-4">🥬</div>
            <h3 style="font-family:'Syne',sans-serif" class="text-xl font-bold text-gray-700 mb-2">Your cart is empty</h3>
            <p class="text-gray-500 mb-6">Browse vendors and add some fresh vegetables!</p>
            <a href="/" class="sw-btn sw-btn-primary px-6 py-2.5">Browse Vendors →</a>
          </div>`;
        return;
      }

      let total = 0;
      let rows = cart.map((item, i) => {
        const price = Number(item.price)||0, qty = Number(item.qty)||0, sub = price*qty;
        total += sub;
        return `<tr class="border-b border-green-50 hover:bg-green-50/50 transition-colors">
          <td class="px-4 py-3 font-semibold text-gray-800">${String(item.productName||'')}</td>
          <td class="px-4 py-3 text-gray-500 text-sm">${String(item.vendorName||'')}</td>
          <td class="px-4 py-3 font-semibold text-green-700">₹${price}</td>
          <td class="px-4 py-3">
            <div class="sw-stepper">
              <button class="sw-stepper-btn" onclick="updateQty(${i},-1)">−</button>
              <span class="sw-stepper-input">${qty}</span>
              <button class="sw-stepper-btn" onclick="updateQty(${i},1)">+</button>
            </div>
          </td>
          <td class="px-4 py-3 font-bold text-green-700">₹${sub}</td>
          <td class="px-4 py-3">
            <button onclick="removeFromCart(${i})" class="sw-btn sw-btn-danger px-3 py-1.5 text-xs">Remove</button>
          </td>
        </tr>`;
      }).join('');

      container.innerHTML = `
        <div class="sw-card overflow-hidden anim-fade-up">
          <div class="overflow-x-auto">
            <table class="sw-table min-w-[600px]">
              <thead><tr>
                <th>Product</th><th>Vendor</th><th>Price</th><th>Quantity</th><th>Subtotal</th><th>Action</th>
              </tr></thead>
              <tbody>${rows}</tbody>
            </table>
          </div>
          <div class="p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 border-t border-green-50">
            <div>
              <span class="text-gray-500 text-sm">Order Total</span>
              <p class="text-2xl font-black text-green-700" style="font-family:'Syne',sans-serif">₹${total}</p>
            </div>
            ${customerLoggedIn === "true"
              ? `<form action="/set-cart" method="POST" onsubmit="prepareCartData(); clearCartAfterCheckout();" class="flex items-center gap-3">
                  <input type="hidden" name="cartData" id="cartData" />
                  <button type="submit" class="sw-btn sw-btn-primary px-8 py-3 text-base">Proceed to Checkout →</button>
                </form>`
              : `<a href="/login" class="sw-btn sw-btn-primary px-8 py-3 text-base">Login to Checkout →</a>`
            }
          </div>
        </div>`;
    }

    document.addEventListener("DOMContentLoaded", renderCart);
  </script>
</body>
</html>
